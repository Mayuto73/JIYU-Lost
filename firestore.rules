rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: lost_items
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, max 100 chars) - Title of the lost item
    //   - description: string (optional, max 1000 chars) - Detailed description
    //   - imageBase64: string (optional, max 800000 chars) - Base64 encoded image data
    //   - category: string (required, '高等部' or '中等部') - School category
    //   - status: string (required, '未受取' or '受取済') - Status of the item
    //   - authorUid: string (required) - UID of the user who reported it
    //   - authorName: string (required, max 50 chars) - Name of the user who reported it
    //   - createdAt: timestamp (required) - When it was reported
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'admin1921@jiyu.ac.jp';
    }

    function isValidLostItem(data) {
      return data.keys().hasAll(['title', 'category', 'status', 'authorUid', 'authorName', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('searchKeywords' in data) || (data.searchKeywords is string && data.searchKeywords.size() <= 500)) &&
             (!('imageBase64' in data) || (data.imageBase64 is string && data.imageBase64.size() <= 800000)) &&
             (!('claimedByUid' in data) || (data.claimedByUid is string && data.claimedByUid.size() <= 100)) &&
             (!('claimedByName' in data) || (data.claimedByName is string && data.claimedByName.size() <= 100)) &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             data.status in ['未受取', '受取済'] &&
             data.authorUid is string && data.authorUid.size() > 0 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 50 &&
             data.createdAt is timestamp;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /lost_items/{itemId} {
      allow read: if true;
      
      allow create: if isAuthenticated() &&
                    isValidLostItem(request.resource.data) &&
                    request.resource.data.authorUid == request.auth.uid;
                    
      allow update: if isAuthenticated() &&
                    isValidLostItem(request.resource.data) &&
                    request.resource.data.authorUid == resource.data.authorUid && // Immutable
                    request.resource.data.authorName == resource.data.authorName && // Immutable
                    request.resource.data.createdAt == resource.data.createdAt && // Immutable
                    (
                      isOwner(resource.data.authorUid) || isAdmin() ||
                      // Claiming the item
                      (
                        !('claimedByUid' in resource.data) && // Was not claimed
                        request.resource.data.claimedByUid == request.auth.uid && // Claiming for self
                        request.resource.data.claimedByName is string &&
                        request.resource.data.status == resource.data.status && // Status unchanged
                        request.resource.data.title == resource.data.title &&
                        request.resource.data.category == resource.data.category &&
                        request.resource.data.get('description', '') == resource.data.get('description', '') &&
                        request.resource.data.get('searchKeywords', '') == resource.data.get('searchKeywords', '') &&
                        request.resource.data.get('imageBase64', '') == resource.data.get('imageBase64', '')
                      ) ||
                      // Claimer marking as received
                      (
                        'claimedByUid' in resource.data &&
                        resource.data.claimedByUid == request.auth.uid &&
                        request.resource.data.claimedByUid == resource.data.claimedByUid &&
                        request.resource.data.claimedByName == resource.data.claimedByName &&
                        request.resource.data.status == '受取済' &&
                        resource.data.status == '未受取' &&
                        request.resource.data.title == resource.data.title &&
                        request.resource.data.category == resource.data.category &&
                        request.resource.data.get('description', '') == resource.data.get('description', '') &&
                        request.resource.data.get('searchKeywords', '') == resource.data.get('searchKeywords', '') &&
                        request.resource.data.get('imageBase64', '') == resource.data.get('imageBase64', '')
                      )
                    );
                    
      allow delete: if isOwner(resource.data.authorUid) || isAdmin();
    }
  }
}
