rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: lost_items
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, max 100 chars) - Title of the lost item
    //   - description: string (optional, max 1000 chars) - Detailed description
    //   - imageBase64: string (optional, max 800000 chars) - Base64 encoded image data
    //   - category: string (required, '高等部' or '中等部') - School category
    //   - status: string (required, '未受取' or '受取済') - Status of the item
    //   - authorUid: string (required) - UID of the user who reported it
    //   - authorName: string (required, max 50 chars) - Name of the user who reported it
    //   - createdAt: timestamp (required) - When it was reported
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'admin1921@jiyu.ac.jp';
    }

    function isValidLostItem(data) {
      return data.keys().hasAll(['title', 'category', 'status', 'authorUid', 'authorName', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             (!('imageBase64' in data) || (data.imageBase64 is string && data.imageBase64.size() <= 800000)) &&
             data.category in ['高等部', '中等部'] &&
             data.status in ['未受取', '受取済'] &&
             data.authorUid is string && data.authorUid.size() > 0 &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 50 &&
             data.createdAt is timestamp;
    }

    match /lost_items/{itemId} {
      allow read: if true;
      
      allow create: if isAuthenticated() &&
                    isValidLostItem(request.resource.data) &&
                    request.resource.data.authorUid == request.auth.uid;
                    
      allow update: if isAuthenticated() &&
                    isValidLostItem(request.resource.data) &&
                    request.resource.data.authorUid == resource.data.authorUid && // Immutable
                    request.resource.data.authorName == resource.data.authorName && // Immutable
                    request.resource.data.createdAt == resource.data.createdAt && // Immutable
                    (
                      isOwner(resource.data.authorUid) || isAdmin()
                    );
                    
      allow delete: if isOwner(resource.data.authorUid) || isAdmin();
    }
  }
}
